# Copy to .env and fill in your credit codes:  cp .env.example .env
# Secrets — leave empty here, paste your real keys into .env (never commit .env).
ANTHROPIC_API_KEY=
ARIZE_API_KEY=
SENTRY_DSN=
FETCH_AI_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
DEEPGRAM_KEY=

# Local service config (defaults work out of the box).
DATABASE_URL=postgresql://lighthouse:lighthouse@localhost:5432/lighthouse
VITE_DATA_URL=http://localhost:8001
MOCK_INBOX_URL=http://localhost:5173/inbox
MOCK_BANK_URL=http://localhost:5173/bank

# 1 = skip live computer-use / external calls, return cached fake results (demo safety net).
DEMO_MODE=0
